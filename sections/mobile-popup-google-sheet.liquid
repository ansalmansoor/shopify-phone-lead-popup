{% liquid
  assign show_popup = false

  case section.settings.show_on
    when 'all'
      assign show_popup = true

    when 'home'
      if template.name == 'index'
        assign show_popup = true
      endif

    when 'product'
      if template.name == 'product'
        assign show_popup = true
      endif

    when 'collection'
      if template.name == 'collection'
        assign show_popup = true
      endif

    when 'cart'
      if template.name == 'cart'
        assign show_popup = true
      endif

    when 'page'
      if template.name == 'page'
        assign show_popup = true
      endif

    when 'specific_urls'
      assign current_url_path = request.path
      assign selected_urls = section.settings.specific_urls | newline_to_br | split: '<br />'

      for selected_url in selected_urls
        assign clean_url = selected_url | strip
        if clean_url != blank and current_url_path == clean_url
          assign show_popup = true
        endif
      endfor
  endcase
%}

{% if section.settings.enable_popup and show_popup %}
  <style>
    #MobilePopup-{{ section.id }} {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999999;
      background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-box {
      background: {{ section.settings.popup_bg_color }};
      color: {{ section.settings.text_color }};
      max-width: {{ section.settings.popup_width }}px;
      width: 100%;
      border-radius: {{ section.settings.border_radius }}px;
      overflow: hidden;
      position: relative;
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
      font-family: inherit;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-close {
      position: absolute;
      top: 12px;
      right: 12px;
      z-index: 3;
      background: {{ section.settings.close_bg_color }};
      color: {{ section.settings.close_text_color }};
      border: none;
      width: 34px;
      height: 34px;
      border-radius: 50%;
      font-size: 22px;
      line-height: 30px;
      cursor: pointer;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-image img {
      width: 100%;
      display: block;
      object-fit: cover;
      max-height: {{ section.settings.image_height }}px;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-content {
      padding: {{ section.settings.content_padding }}px;
      text-align: {{ section.settings.text_alignment }};
    }

    #MobilePopup-{{ section.id }} h2 {
      margin: 0 0 10px;
      font-size: {{ section.settings.heading_size }}px;
      color: {{ section.settings.heading_color }};
      line-height: 1.2;
      font-weight: 700;
      text-transform: uppercase;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-text {
      margin-bottom: 18px;
      font-size: {{ section.settings.text_size }}px;
      line-height: 1.5;
      color: {{ section.settings.text_color }};
    }

    #MobilePopup-{{ section.id }} .mobile-popup-form {
      width: 100%;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-email {
      width: 100%;
      height: {{ section.settings.input_height }}px;
      padding: 0 14px;
      border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
      border-radius: {{ section.settings.input_radius }}px;
      font-size: {{ section.settings.input_font_size }}px;
      color: {{ section.settings.input_text_color }};
      background: {{ section.settings.input_bg_color }};
      box-sizing: border-box;
      text-align: {{ section.settings.email_text_alignment }};
      outline: none;
      margin-bottom: 14px;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-email::placeholder {
      color: {{ section.settings.input_placeholder_color }};
      opacity: 1;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-phone-row {
      display: flex;
      align-items: center;
      width: 100%;
      margin-bottom: 14px;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-country-code {
      height: {{ section.settings.input_height }}px;
      width: {{ section.settings.country_code_width }}px;
      min-width: {{ section.settings.country_code_width }}px;
      padding: 0 6px;
      border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
      border-right: 0;
      border-radius: {{ section.settings.input_radius }}px 0 0 {{ section.settings.input_radius }}px;
      background: {{ section.settings.country_code_bg_color }};
      color: {{ section.settings.country_code_text_color }};
      font-size: {{ section.settings.country_code_font_size }}px;
      box-sizing: border-box;
      outline: none;
      cursor: pointer;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-phone {
      width: 100%;
      height: {{ section.settings.input_height }}px;
      padding: 0 14px;
      border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
      border-radius: 0 {{ section.settings.input_radius }}px {{ section.settings.input_radius }}px 0;
      font-size: {{ section.settings.input_font_size }}px;
      color: {{ section.settings.input_text_color }};
      background: {{ section.settings.input_bg_color }};
      box-sizing: border-box;
      text-align: {{ section.settings.phone_text_alignment }};
      outline: none;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-phone::placeholder {
      color: {{ section.settings.input_placeholder_color }};
      opacity: 1;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-policy {
      display: flex;
      gap: 8px;
      align-items: flex-start;
      text-align: left;
      font-size: 12px;
      line-height: 1.4;
      margin: 0 0 14px;
      color: {{ section.settings.text_color }};
    }

    #MobilePopup-{{ section.id }} .mobile-popup-policy input {
      width: auto;
      margin-top: 3px;
      flex-shrink: 0;
      accent-color: {{ section.settings.button_bg_color }};
    }

    #MobilePopup-{{ section.id }} .mobile-popup-policy a {
      color: {{ section.settings.button_bg_color }};
      text-decoration: underline;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-submit {
      width: 100%;
      height: {{ section.settings.button_height }}px;
      padding: 0 18px;
      border: none;
      border-radius: {{ section.settings.button_radius }}px;
      background: {{ section.settings.button_bg_color }};
      color: {{ section.settings.button_text_color }};
      font-size: {{ section.settings.button_font_size }}px;
      font-weight: 700;
      letter-spacing: {{ section.settings.button_letter_spacing }}px;
      text-transform: {{ section.settings.button_text_transform }};
      cursor: pointer;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-submit:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    #MobilePopup-{{ section.id }} .mobile-popup-message {
      margin-top: 12px;
      font-size: 14px;
      text-align: center;
    }

    @media screen and (max-width: 749px) {
      #MobilePopup-{{ section.id }} .mobile-popup-content {
        padding: {{ section.settings.mobile_content_padding }}px;
      }

      #MobilePopup-{{ section.id }} h2 {
        font-size: {{ section.settings.mobile_heading_size }}px;
      }

      #MobilePopup-{{ section.id }} .mobile-popup-box {
        max-width: 95%;
      }
    }
  </style>

  <div id="MobilePopup-{{ section.id }}">
    <div class="mobile-popup-box">
      {% if section.settings.show_close_button %}
        <button class="mobile-popup-close" type="button" aria-label="Close popup">
          &times;
        </button>
      {% endif %}

      {% if section.settings.popup_image != blank %}
        <div class="mobile-popup-image">
          <img
            src="{{ section.settings.popup_image | image_url: width: 1000 }}"
            alt="{{ section.settings.image_alt | default: section.settings.heading | escape }}"
            loading="lazy"
          >
        </div>
      {% endif %}

      <div class="mobile-popup-content">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="mobile-popup-text">
            {{ section.settings.text }}
          </div>
        {% endif %}

        <form class="mobile-popup-form">
          {% if section.settings.enable_email %}
            <input
              type="email"
              class="mobile-popup-email"
              placeholder="{{ section.settings.email_placeholder }}"
              autocomplete="email"
              {% if section.settings.email_required %}required{% endif %}
            >
          {% endif %}

          {% if section.settings.enable_phone %}
            <div class="mobile-popup-phone-row">
              <select class="mobile-popup-country-code" aria-label="Country code">
                <option value="+91" {% if section.settings.default_country_code == '+91' %}selected{% endif %}>IN +91</option>
                <option value="+971" {% if section.settings.default_country_code == '+971' %}selected{% endif %}>AE +971</option>
                <option value="+1" {% if section.settings.default_country_code == '+1' %}selected{% endif %}>US/CA +1</option>
                <option value="+44" {% if section.settings.default_country_code == '+44' %}selected{% endif %}>UK +44</option>
                <option value="+61" {% if section.settings.default_country_code == '+61' %}selected{% endif %}>AU +61</option>
                <option value="+65" {% if section.settings.default_country_code == '+65' %}selected{% endif %}>SG +65</option>
                <option value="+60" {% if section.settings.default_country_code == '+60' %}selected{% endif %}>MY +60</option>
                <option value="+966" {% if section.settings.default_country_code == '+966' %}selected{% endif %}>SA +966</option>
                <option value="+974" {% if section.settings.default_country_code == '+974' %}selected{% endif %}>QA +974</option>
                <option value="+965" {% if section.settings.default_country_code == '+965' %}selected{% endif %}>KW +965</option>
                <option value="+968" {% if section.settings.default_country_code == '+968' %}selected{% endif %}>OM +968</option>
                <option value="+973" {% if section.settings.default_country_code == '+973' %}selected{% endif %}>BH +973</option>
              </select>

              <input
                type="tel"
                class="mobile-popup-phone"
                placeholder="{{ section.settings.phone_placeholder }}"
                maxlength="{{ section.settings.phone_max_length }}"
                autocomplete="tel"
                inputmode="numeric"
                {% if section.settings.phone_required %}required{% endif %}
              >
            </div>
          {% endif %}

          {% if section.settings.enable_policy_checkbox %}
            <label class="mobile-popup-policy">
              <input type="checkbox" class="mobile-popup-policy-checkbox" required>
              <span>
                {{ section.settings.policy_text }}
                {% if section.settings.policy_link != blank %}
                  <a href="{{ section.settings.policy_link }}" target="_blank" rel="noopener">
                    {{ section.settings.policy_link_text }}
                  </a>
                {% endif %}
              </span>
            </label>
          {% endif %}

          <button type="submit" class="mobile-popup-submit">
            {{ section.settings.button_text }}
          </button>

          <div class="mobile-popup-message"></div>
        </form>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const popup = document.getElementById("MobilePopup-{{ section.id }}");
      if (!popup) return;

      const form = popup.querySelector(".mobile-popup-form");
      const emailInput = popup.querySelector(".mobile-popup-email");
      const phoneInput = popup.querySelector(".mobile-popup-phone");
      const countrySelect = popup.querySelector(".mobile-popup-country-code");
      const policyCheckbox = popup.querySelector(".mobile-popup-policy-checkbox");
      const closeBtn = popup.querySelector(".mobile-popup-close");
      const message = popup.querySelector(".mobile-popup-message");
      const submitBtn = popup.querySelector(".mobile-popup-submit");

      const googleScriptUrl = {{ section.settings.google_script_url | json }};
      const googleSheetId = {{ section.settings.google_sheet_id | json }};
      const popupDelay = {{ section.settings.popup_delay | times: 1000 }};
      const showOnce = {{ section.settings.show_once | json }};

      const enableEmail = {{ section.settings.enable_email | json }};
      const emailRequired = {{ section.settings.email_required | json }};
      const enablePhone = {{ section.settings.enable_phone | json }};
      const phoneRequired = {{ section.settings.phone_required | json }};
      const enablePolicy = {{ section.settings.enable_policy_checkbox | json }};

      const storageKey = "lead_popup_submitted_{{ section.id }}";
      const closeKey = "lead_popup_closed_{{ section.id }}";
      const shopifyPayloadVersion = "shopify-v5-fast-submit";

      function openPopup() {
        if (showOnce && localStorage.getItem(storageKey)) return;
        if (sessionStorage.getItem(closeKey)) return;
        popup.style.display = "flex";
      }

      function closePopup() {
        popup.style.display = "none";
        sessionStorage.setItem(closeKey, "true");
      }

      function sendLeadFast(payload) {
        const payloadString = JSON.stringify(payload);

        if (navigator.sendBeacon) {
          const blob = new Blob([payloadString], {
            type: "text/plain;charset=UTF-8"
          });

          const beaconSent = navigator.sendBeacon(googleScriptUrl, blob);

          if (beaconSent) {
            return;
          }
        }

        fetch(googleScriptUrl, {
          method: "POST",
          mode: "no-cors",
          keepalive: true,
          headers: {
            "Content-Type": "text/plain;charset=utf-8"
          },
          body: payloadString
        }).catch(function () {});
      }

      setTimeout(openPopup, popupDelay);

      if (closeBtn) {
        closeBtn.addEventListener("click", closePopup);
      }

      popup.addEventListener("click", function (event) {
        if (event.target === popup && {{ section.settings.close_on_overlay_click | json }}) {
          closePopup();
        }
      });

      form.addEventListener("submit", function (event) {
        event.preventDefault();

        const email = emailInput ? emailInput.value.trim() : "";
        const phone = phoneInput ? phoneInput.value.trim().replace(/\D/g, "") : "";
        const countryCode = countrySelect ? countrySelect.value : {{ section.settings.default_country_code | json }};
        const countryLabel = countrySelect ? countrySelect.options[countrySelect.selectedIndex].text : "";

        if (!enableEmail && !enablePhone) {
          message.style.color = "red";
          message.textContent = "Please enable email or mobile field.";
          return;
        }

        if (enableEmail && emailRequired) {
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

          if (!emailRegex.test(email)) {
            message.style.color = "red";
            message.textContent = {{ section.settings.email_error_message | json }};
            return;
          }
        }

        if (enablePhone && phoneRequired) {
          const phoneRegex = new RegExp("^[0-9]{" + {{ section.settings.phone_min_length }} + "," + {{ section.settings.phone_max_length }} + "}$");

          if (!phoneRegex.test(phone)) {
            message.style.color = "red";
            message.textContent = {{ section.settings.phone_error_message | json }};
            return;
          }
        }

        if (enablePolicy && policyCheckbox && !policyCheckbox.checked) {
          message.style.color = "red";
          message.textContent = {{ section.settings.policy_error_message | json }};
          return;
        }

        if (!googleScriptUrl) {
          message.style.color = "red";
          message.textContent = "Google Script URL missing.";
          return;
        }

        if (!googleSheetId) {
          message.style.color = "red";
          message.textContent = "Google Sheet ID missing.";
          return;
        }

        const payload = {
          email: email,
          country_label: countryLabel,
          country_code: countryCode,
          mobile: phone,
          full_mobile: phone ? countryCode + phone : "",
          sheet_id: googleSheetId,
          page: window.location.href,
          page_path: window.location.pathname,
          source: "Shopify Lead Popup",
          popup_title: {{ section.settings.heading | json }},
          policy_accepted: enablePolicy ? "Yes" : "Not Required",
          policy_text: {{ section.settings.policy_text | json }},
          user_agent: navigator.userAgent,
          browser_submitted_at: new Date().toISOString(),
          shopify_payload_version: shopifyPayloadVersion
        };

        submitBtn.disabled = true;
        localStorage.setItem(storageKey, "true");

        message.style.color = "green";
        message.textContent = {{ section.settings.success_message | json }};

        sendLeadFast(payload);

        setTimeout(function () {
          popup.style.display = "none";
          submitBtn.disabled = false;
        }, 500);
      });
    });
  </script>
{% endif %}

{% schema %}
